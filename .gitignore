# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Environment secrets — NEVER commit these
.env
backend/.env

# Node
node_modules/
frontend/node_modules/

# ML model weights (too large for git — use git-lfs or HF Model Hub)
backend/ml/models/**/*.pt
backend/ml/models/**/*.pth
# Keep the directory structure but not the weights
\!backend/ml/models/.gitkeep

# Large datasets — Parquet files are tracked via manifest.json MD5s
# Uncomment below if you want to exclude them from git (recommended for large repos)
# backend/ml/datasets/*.parquet

# Generated artifacts (regenerated by CI)
backend/ml/experiments/comparison_chart.png
backend/ml/experiments/comparison_table.json

# Frontend build (rebuilt by CD job before deploy)
frontend/dist/

# Test artifacts
test-results/
.pytest_cache/
*.xml

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
